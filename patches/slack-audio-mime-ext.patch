diff --git a/gateway/platforms/slack.py b/gateway/platforms/slack.py
index c8974699d..c71f98190 100644
--- a/gateway/platforms/slack.py
+++ b/gateway/platforms/slack.py
@@ -2530,9 +2530,33 @@ class SlackAdapter(BasePlatformAdapter):
                         )
             elif mimetype.startswith("audio/") and url:
                 try:
-                    ext = "." + mimetype.split("/")[-1].split(";")[0]
-                    if ext not in {".ogg", ".mp3", ".wav", ".webm", ".m4a"}:
-                        ext = ".ogg"
+                    # Map the audio MIME type to the extension the STT endpoint
+                    # expects. Deriving it from the MIME subtype alone breaks for
+                    # container types: audio/mp4 -> ".mp4", audio/x-m4a ->
+                    # ".x-m4a", audio/mpeg -> ".mpeg" -- none were in the allowlist
+                    # below, so they were forced to ".ogg" while the bytes stayed
+                    # MP4/AAC/MP3. The transcription API then rejects the
+                    # extension/content mismatch as "corrupted or unsupported"
+                    # (exactly how macOS Slack voice clips, audio/mp4, fail).
+                    _audio_mime_ext = {
+                        "audio/mp4": ".m4a",
+                        "audio/x-m4a": ".m4a",
+                        "audio/m4a": ".m4a",
+                        "audio/mpeg": ".mp3",
+                        "audio/mp3": ".mp3",
+                        "audio/wav": ".wav",
+                        "audio/x-wav": ".wav",
+                        "audio/wave": ".wav",
+                        "audio/webm": ".webm",
+                        "audio/ogg": ".ogg",
+                        "audio/opus": ".ogg",
+                    }
+                    mime = mimetype.split(";")[0].strip().lower()
+                    ext = _audio_mime_ext.get(mime)
+                    if ext is None:
+                        ext = "." + mime.split("/")[-1]
+                        if ext not in {".ogg", ".mp3", ".wav", ".webm", ".m4a", ".mp4", ".flac"}:
+                            ext = ".ogg"
                     cached = await self._download_slack_file(
                         url, ext, audio=True, team_id=team_id
                     )
