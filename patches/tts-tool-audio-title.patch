 # Provider: OpenAI TTS (also used by every OpenAI-compatible TTS endpoint —
 # DeepInfra delegates here via _generate_deepinfra_tts).
 # ===========================================================================
+def _rename_with_title(path: str, title: str) -> Optional[str]:
+    """Rename a generated audio file to a human *title* (from audio-gateway's
+    X-Audio-Title header) so the Slack attachment shows a real name instead of
+    ``tts_<timestamp>``. Keeps the original extension; strips filesystem-unsafe
+    characters; falls back to a timestamp suffix on name collision. Returns the
+    new path, or ``None`` on any failure (caller keeps the original).
+    LOCAL MODIFICATION — see patches/tts-tool-audio-title.patch.
+    """
+    clean = re.sub(r'[<>:"/\\|?*\x00-\x1f]', "", title)
+    clean = re.sub(r"\s+", " ", clean).strip().rstrip(".")[:80].strip()
+    if not clean:
+        return None
+    src = Path(path)
+    target = src.with_name(f"{clean}{src.suffix}")
+    try:
+        if target.exists() and target != src:
+            stamp = datetime.datetime.now().strftime("%H%M%S")
+            target = src.with_name(f"{clean} {stamp}{src.suffix}")
+        src.rename(target)
+        return str(target)
+    except OSError as exc:
+        logger.warning("Could not rename audio to title %r: %s", clean, exc)
+        return None
+
