 # Main API
 # ---------------------------------------------------------------------------
@@ -744,6 +1101,34 @@ def check_command_security(command: str) -> dict:
     if not cfg["tirith_enabled"]:
         return {"action": "allow", "findings": [], "summary": ""}
 
+    # LOCAL MODIFICATION (patches/tirith-argo-allowlist-and-download-guard.patch):
+    # close tirith's download-then-execute gap. Deliberately placed BEFORE the
+    # circuit breaker and the argo allowlist, so it still holds when tirith is
+    # unavailable/fail-open and can never be bypassed by an allowlisted host.
+    _dte_reason = _download_then_execute_reason(command)
+    if _dte_reason:
+        return {
+            "action": "block",
+            "findings": [{
+                "rule_id": "download_then_execute",
+                "severity": "HIGH",
+                "title": "Download then execute",
+                "description": (
+                    f"Command downloads content and then runs it: {_dte_reason}. "
+                    "This is the two-step equivalent of `curl … | sh`, which "
+                    "tirith blocks but does not detect in this form. Downloaded "
+                    "content would execute without inspection.\n"
+                    "  If this is genuinely intended, fetch and inspect the file "
+                    "in one step, then run it as a separate, explicit command."
+                ),
+                "evidence": [{"type": "command_pattern",
+                              "pattern": "download then execute",
+                              "matched": command[:200]}],
+                "mitre_id": "T1059.004",
+            }],
+            "summary": "download-then-execute blocked (local hardening)",
+        }
+
     # Circuit breaker: if tirith has crashed _CRASH_LIMIT times in a row,
     # stop trying for the rest of the process.  Without this, a corrupted
     # or missing binary causes every tool call to hit the same spawn failure
@@ -752,6 +1137,11 @@ def check_command_security(command: str) -> dict:
     if _circuit_open:
         return {"action": "allow", "findings": [], "summary": "tirith disabled (circuit breaker)"}
 
+    # LOCAL MODIFICATION (patches/tirith-argo-allowlist-and-download-guard.patch):
+    # trusted personal API pipelines bypass tirith entirely.
+    if _is_argo_only_pipeline(command):
+        return {"action": "allow", "findings": [], "summary": "trusted personal API pipeline (tirith bypassed)"}
+
     # Unsupported platform (Windows etc.) — tirith has no binary here and
