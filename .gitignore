.DS_Store

# Hermes runtime state — cron jobs registry + per-run output
cron/jobs.json
cron/output/
cron/.jobs.lock
cron/ticker_heartbeat
cron/ticker_last_success
# v0.19.0: per-run execution history moved into a SQLite db
cron/executions.db

# Hermes briefing state — local-only city + vacation flag.
# Edits (vacation_until before a trip, city when remote) shouldn't pollute
# git history. Template lives next to it as briefing-state.example.json.
scripts/briefing-state.json

# Hermes capture skill cache — repos + ticktick_projects, refreshed on miss.
# Local-only runtime cache; template lives next to it as state.example.json.
skills/capture/state.json

# Hermes karakeep skill cache — lists + tags, refreshed on miss.
# Local-only runtime cache; template lives next to it as state.example.json.
skills/karakeep/state.json

# Claude Code runtime state (but keep committed skills)
.claude/*
!.claude/skills/

# Python
__pycache__/
*.pyc
